/*
  # セキュリティヘッダー
  # 第三者によるサイバー攻撃（XSS・クリックジャッキング・MIME sniffing等）を防ぐ

  # 他サイトへの埋め込みを禁止（クリックジャッキング対策）
  X-Frame-Options: DENY

  # ブラウザのMIMEタイプ推測を禁止（MIME sniffing攻撃対策）
  X-Content-Type-Options: nosniff

  # リファラ情報を最小限に制限（URLからの情報漏えい防止）
  Referrer-Policy: strict-origin-when-cross-origin

  # 許可する外部リソースを明示（CSP: 未許可スクリプトの実行をブロック）
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none';

  # HTTPSを強制（中間者攻撃対策）
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # 許可するブラウザ機能を制限
  Permissions-Policy: camera=(), microphone=(), geolocation=()
